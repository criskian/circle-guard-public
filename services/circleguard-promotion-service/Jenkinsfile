pipeline {
    agent any
    options {
        timestamps()
        ansiColor('xterm')
        timeout(time: 60, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }
    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'stage', 'master'],
               description: 'Target deployment environment')
    }
    environment {
        SERVICE     = 'circleguard-promotion-service'
        SHORT_NAME  = 'promotion'
        PORT        = '8088'
        REPO_ROOT   = "${WORKSPACE}"
        IMAGE_TAG   = "promotion-${BUILD_NUMBER}"
        GRADLE_OPTS = '-Xmx512m -Dfile.encoding=UTF-8'
        SONAR_HOST  = 'http://sonarqube:9000'
    }
    stages {
        stage('Checkout') {
            steps {
                dir("${REPO_ROOT}") { sh 'git log -1 --oneline' }
            }
        }
        stage('Build') {
            steps {
                dir("${REPO_ROOT}") {
                    sh './gradlew :services:circleguard-promotion-service:bootJar --no-daemon -x test --max-workers 1'
                }
            }
        }
        stage('Unit Tests') {
            steps {
                dir("${REPO_ROOT}") {
                    sh './gradlew :services:circleguard-promotion-service:test --no-daemon --info --max-workers 1'
                }
            }
            post {
                always {
                    junit testResults: 'services/circleguard-promotion-service/build/test-results/test/**/*.xml',
                          allowEmptyResults: true
                    publishHTML target: [
                        allowMissing: true,
                        reportDir:   'services/circleguard-promotion-service/build/reports/tests/test',
                        reportFiles: 'index.html',
                        reportName:  'Promotion Unit Test Report'
                    ]
                }
            }
        }
        stage('Integration Tests') {
            steps {
                dir("${REPO_ROOT}") {
                    sh './gradlew :services:circleguard-promotion-service:integrationTest --no-daemon --info --max-workers 1'
                }
            }
            post {
                always {
                    junit testResults: 'services/circleguard-promotion-service/build/test-results/integrationTest/**/*.xml',
                          allowEmptyResults: true
                    publishHTML target: [
                        allowMissing: true,
                        reportDir:   'services/circleguard-promotion-service/build/reports/tests/integrationTest',
                        reportFiles: 'index.html',
                        reportName:  'Promotion Integration Test Report'
                    ]
                }
            }
        }
        stage('Coverage') {
            steps {
                dir("${REPO_ROOT}") {
                    sh './gradlew :services:circleguard-promotion-service:jacocoTestReport --no-daemon --max-workers 1'
                }
            }
            post {
                always {
                    jacoco execPattern: 'services/circleguard-promotion-service/build/jacoco/*.exec',
                           classPattern: 'services/circleguard-promotion-service/build/classes/kotlin/main',
                           sourcePattern: 'services/circleguard-promotion-service/src/main/java',
                           minimumLineCoverage: '60',
                           changeBuildStatus: false
                    publishHTML target: [
                        allowMissing: true,
                        reportDir:   'services/circleguard-promotion-service/build/reports/jacoco/test/html',
                        reportFiles: 'index.html',
                        reportName:  'Promotion Coverage Report'
                    ]
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir("${REPO_ROOT}") {
                    withSonarQubeEnv(installationName: 'SonarQube') {
                        sh './gradlew classes testClasses sonar --no-daemon --max-workers 1'
                    }
                }
            }
        }
        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
        stage('Docker Build') {
            steps {
                dir("${REPO_ROOT}") {
                    sh """
                        docker build -f services/circleguard-promotion-service/Dockerfile \
                          -t circleguard-promotion-service:${IMAGE_TAG} \
                          -t circleguard-promotion-service:latest .
                    """
                }
            }
        }
        stage('Trivy Scan') {
            steps {
                dir("${REPO_ROOT}") {
                    sh """
                        which trivy 2>/dev/null || curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b /usr/local/bin
                        trivy image --severity HIGH,CRITICAL --exit-code 1 \
                          --format json \
                          --output trivy-promotion-${BUILD_NUMBER}.json \
                          circleguard-promotion-service:${IMAGE_TAG} || true
                    """
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'trivy-promotion-*.json', allowEmptyArchive: true
                }
            }
        }
        stage('Deploy Dev') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps {
                dir("${REPO_ROOT}") {
                    sh 'docker compose -f docker-compose.dev.yml up -d --no-deps --build promotion-service || true'
                }
            }
        }
        stage('Deploy Stage') {
            when { expression { params.ENVIRONMENT in ['stage', 'master'] } }
            steps {
                dir("${REPO_ROOT}") {
                    sh 'docker tag circleguard-promotion-service:latest circleguard-promotion-service:stage-latest'
                    sh 'kubectl kustomize k8s/overlays/stage --load-restrictor=LoadRestrictionsNone | kubectl apply -f - || true'
                    sh 'kubectl rollout status deployment/promotion-service -n circleguard-stage --timeout=120s || true'
                }
            }
        }
        stage('E2E Tests') {
            when { expression { params.ENVIRONMENT in ['stage', 'master'] } }
            steps {
                dir("${REPO_ROOT}/tests/e2e") {
                    sh """
                        newman run circleguard-e2e.postman_collection.json \
                          --environment stage.env.json \
                          --reporters cli,junit,htmlextra \
                          --reporter-junit-export reports/e2e-promotion-${BUILD_NUMBER}.xml \
                          --reporter-htmlextra-export reports/e2e-promotion-${BUILD_NUMBER}.html \
                          --bail || true
                    """
                }
            }
            post {
                always {
                    junit testResults: 'tests/e2e/reports/*.xml', allowEmptyResults: true
                }
            }
        }
        stage('Promote Prod') {
            when { expression { params.ENVIRONMENT == 'master' } }
            steps {
                timeout(time: 30, unit: 'MINUTES') {
                    input message: "¿Aprobar despliegue de ${env.SERVICE} a producción?",
                          ok: 'Aprobar'
                }
                dir("${REPO_ROOT}") {
                    sh 'docker tag circleguard-promotion-service:stage-latest circleguard-promotion-service:prod-latest'
                    sh 'kubectl kustomize k8s/overlays/prod --load-restrictor=LoadRestrictionsNone | kubectl apply -f - || true'
                    sh 'kubectl rollout status deployment/promotion-service -n circleguard-prod --timeout=180s || true'
                }
            }
        }
        stage('Release Notes') {
            when { expression { params.ENVIRONMENT == 'master' } }
            steps {
                dir("${REPO_ROOT}") {
                    sh "pwsh -File ci/scripts/generate-release-notes.ps1 -Service circleguard-promotion-service -BuildNumber ${BUILD_NUMBER} || true"
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'RELEASE_NOTES_*.md,CHANGELOG.md', allowEmptyArchive: true
                }
            }
        }
    }
    post {
        failure {
            emailext(
                subject: "FALLO — ${env.SERVICE} Build #${env.BUILD_NUMBER} [${params.ENVIRONMENT}]",
                body: """<h2>Pipeline Fallido</h2>
                        <p><b>Servicio:</b> ${env.SERVICE}</p>
                        <p><b>Build:</b> #${env.BUILD_NUMBER}</p>
                        <p><b>Ambiente:</b> ${params.ENVIRONMENT}</p>
                        <p>Ver detalles: <a href="${env.BUILD_URL}">${env.BUILD_URL}</a></p>""",
                to: 'admin@circleguard.local',
                mimeType: 'text/html'
            )
        }
        always {
            cleanWs cleanWhenNotBuilt: false, deleteDirs: true, disableDeferredWipeout: true
        }
    }
}
